# Default report mode must work without LLM calls.
REPORT_MODE=rule_based

# Optional AI-enhanced mode. Leave blank unless REPORT_MODE=llm_enhanced.
LLM_PROVIDER=
LLM_MODEL=
LLM_API_KEY=

# Database, auth, and storage are intentionally undecided in the foundation commit.
DATABASE_URL=
AUTH_SECRET=
STORAGE_BUCKET=

