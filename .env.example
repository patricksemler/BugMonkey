# Default report mode must work without LLM calls.
REPORT_MODE=rule_based

# Optional AI-enhanced mode. Leave blank unless REPORT_MODE=llm_enhanced.
LLM_PROVIDER=
LLM_MODEL=
LLM_API_KEY=

# Optional future Supabase wiring. Leave blank for the static web build.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
DATABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_EVIDENCE_BUCKET=
